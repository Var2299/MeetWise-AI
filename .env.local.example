# ─── MongoDB (recommended for production) ──────────────────────────────────
# Free tier: https://www.mongodb.com/cloud/atlas
# Without this, app falls back to data/users.json (single-process demo only)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=meetwise

# ─── Required for real AI summaries ────────────────────────────────────────
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Required for JWT auth ──────────────────────────────────────────────────
# Use a long random string in production: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret

# ─── Required for sending summary emails ───────────────────────────────────
# Use a Gmail App Password (not your real password)
# https://support.google.com/accounts/answer/185833
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password

# ─── App environment ────────────────────────────────────────────────────────
NODE_ENV=development
